                    "name": "自定义代码块",
                    "valueType": "string",
                    "value": "\nimport socket\n#创建socket对象\nsock = socket.socket()\n#绑定端口\nsock.bind(('127.0.0.1',13001))\n#开始监听\nsock.listen(5)\nwhile True:\n    # 常驻监听\n    for 端口 in 服务端端口列表.replace('，',',').replace(' ','').split(','):\n        # 等待用户连接，形成阻塞\n        conn,address = sock.accept()\n        # 接收客户端消息内容\n        data = conn.recv(4096)\n        print(data.decode('UTF8'))\n        logger.info(\"分配的端口是：{}\".format(str(端口)), exc_info=True)\n        # 二维码 = 中间客户端(端口,data.decode('UTF8'))\n        # 回消息给客户端\n        conn.send(str(端口).encode('UTF8'))\n        logger.info(\"已发送端口消息给客户端\", exc_info=True)",
